<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.MahaiakController"
            prefWidth="500"
            prefHeight="400">

    <top>
        <ToolBar styleClass="tool-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16;"/>
                <TextField fx:id="txtBilatu" promptText="Bilatu mahaia..." prefWidth="250" styleClass="login-input"/>
            </HBox>
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnAdd" text="Gehitu" onAction="#gehituMahai" styleClass="action-button"/>
            <Button fx:id="btnEdit" text="Editatu" onAction="#editatuMahai" styleClass="action-button"/>
            <Button fx:id="btnDelete" text="Ezabatu" onAction="#ezabatuMahai" styleClass="action-button"/>
        </ToolBar>
    </top>

    <center>
        <TableView fx:id="mahaiakTable" prefHeight="300">
            <columns>
                <TableColumn fx:id="colIzena" text="Izena" prefWidth="160"/>
                <TableColumn fx:id="colEgoera" text="Egoera" prefWidth="200"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
