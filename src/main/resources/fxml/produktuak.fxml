<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.ProduktuakController"
            prefWidth="900"
            prefHeight="500">

    <top>
        <ToolBar styleClass="tool-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16;"/>
                <TextField fx:id="txtBilatu" promptText="Bilatu produktua..." prefWidth="250" styleClass="login-input"/>
            </HBox>
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnAdd" text="Gehitu" onAction="#gehituProduktua" styleClass="action-button"/>
            <Button fx:id="btnEdit" text="Editatu" onAction="#editatuProduktua" styleClass="action-button"/>
            <Button fx:id="btnDelete" text="Ezabatu" onAction="#ezabatuProduktua" styleClass="action-button"/>

            <Separator orientation="VERTICAL"/>

            <Label text="Mota:" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbMotak" prefWidth="150"/>
        </ToolBar>
    </top>

    <center>
        <TableView fx:id="produktuTable">
            <columns>
                <TableColumn fx:id="colIzena" text="Izena" prefWidth="250"/>
                <TableColumn fx:id="colPrezioa" text="Prezioa" prefWidth="100"/>
                <TableColumn fx:id="colStock" text="Stock" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
