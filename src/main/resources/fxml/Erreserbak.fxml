<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.ErreserbakController"
            prefWidth="1280"
            prefHeight="460">

    <top>
        <ToolBar styleClass="tool-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16;"/>
                <TextField fx:id="txtBilatu" promptText="Bilatu erreserba..." prefWidth="250" styleClass="login-input"/>
            </HBox>
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnAdd" text="Gehitu" onAction="#gehituErreserba" styleClass="action-button"/>
            <Button fx:id="btnEdit" text="Editatu" onAction="#editatuErreserba" styleClass="action-button"/>
            <Button fx:id="btnDelete" text="Ezabatu" onAction="#ezabatuErreserba" styleClass="action-button"/>
        </ToolBar>
    </top>

    <center>
        <TableView fx:id="erreserbakTable">
            <columns>
                <TableColumn fx:id="colData" text="Data eta ordua" prefWidth="150"/>
                <TableColumn fx:id="colMota" text="Mota" prefWidth="100"/>
                <TableColumn fx:id="colBezeroa" text="Bezeroa" prefWidth="170"/>
                <TableColumn fx:id="colMahaia" text="Mahaia" prefWidth="180"/>
            </columns>
        </TableView>
    </center>
</BorderPane>