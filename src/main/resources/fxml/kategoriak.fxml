<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.KategoriakController"
            prefWidth="500"
            prefHeight="400">

    <!-- Barra superior con búsqueda y botones -->
    <top>
        <ToolBar styleClass="tool-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16;"/>
                <TextField fx:id="txtBilatu" promptText="Bilatu kategoria..." prefWidth="250" styleClass="login-input"/>
            </HBox>
            <Separator orientation="VERTICAL" />
            <Button fx:id="btnAdd" text="Gehitu" onAction="#gehituKategoria" styleClass="action-button"/>
            <Button fx:id="btnEdit" text="Editatu" onAction="#editatuKategoria" styleClass="action-button"/>
            <Button fx:id="btnDelete" text="Ezabatu" onAction="#ezabatuKategoria" styleClass="action-button"/>
        </ToolBar>
    </top>

    <!-- Tabla en el centro -->
    <center>
        <TableView fx:id="kategoriakTable" prefHeight="300">
            <columns>
                <TableColumn fx:id="colIzena" text="Izena" prefWidth="480"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
