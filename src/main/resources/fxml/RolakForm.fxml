<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="kontrola.RolakFormController"
            prefWidth="900"
            prefHeight="500">

    <top>
        <ToolBar styleClass="tool-bar">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16;"/>
                <TextField fx:id="txtBilatu" promptText="Bilatu langilea..." prefWidth="250" styleClass="login-input"/>
            </HBox>
            <Pane HBox.hgrow="ALWAYS" />
            <Label text="Langileen Kudeaketa" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        </ToolBar>
    </top>

    <center>
        <TableView fx:id="langileakTable">
            <columns>
                <TableColumn fx:id="colIzena" text="Izena" prefWidth="150"/>
                <TableColumn fx:id="colAbizena" text="Abizena" prefWidth="150"/>
                <TableColumn fx:id="colErabiltzailea" text="Erabiltzailea" prefWidth="120"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
                <TableColumn fx:id="colRola" text="Rola" prefWidth="120"/>
                <TableColumn fx:id="colChat" text="Chat Baimena" prefWidth="120"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
